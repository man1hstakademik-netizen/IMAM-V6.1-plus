rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && userDocExists() && 
        (getUserData().role == 'admin' || getUserData().role == 'developer');
    }
    
    function isStaff() {
      return isSignedIn() && userDocExists() && (
        getUserData().role == 'admin' || 
        getUserData().role == 'developer' || 
        getUserData().role == 'Guru' || 
        getUserData().role == 'Staf' || 
        getUserData().role == 'Wali Kelas' ||
        getUserData().role == 'kepala_madrasah'
      );
    }

    // Validate academic year exists (KRITIS)
    function academicYearExists(yearId) {
      return exists(/databases/$(database)/documents/academic_years/$(yearId));
    }

    // --- Collection Rules ---

    // User Profiles (Auth layer)
    // docId = authUid (Firebase Auth UID)
    match /users/{userId} {
      // Izinkan baca jika masuk log (untuk pencarian identitas/ID Card)
      allow read: if isSignedIn();
      // User bisa buat akunnya sendiri, Admin bisa buatkan akun siapa saja
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // User bisa update dirinya sendiri, Admin bisa update siapa saja
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Admin bisa hapus akun user
      allow delete: if isAdmin();
      
      // Validate required fields
      allow write: if request.resource.data.schemaVersion == 1 &&
                      request.resource.data.profileType in ['student', 'teacher', 'admin', 'staff'] &&
                      request.resource.data.email != null;
    }

    // Data Master (Siswa & Guru)
    match /students/{nisn} {
      allow get: if true; 
      allow list: if isSignedIn();
      allow write: if isStaff();
    }
    match /teachers/{nip} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Akademik (Jurnal, Tugas, Nilai)
    match /journals/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      
      allow create: if request.resource.data.academicYearId != null &&
                       request.resource.data.teacherId != null &&
                       request.resource.data.classId != null &&
                       request.resource.data.schemaVersion == 1 &&
                       request.resource.data.createdAt != null &&
                       academicYearExists(request.resource.data.academicYearId);
    }
    match /assignments/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      
      allow create: if request.resource.data.academicYearId != null &&
                       request.resource.data.teacherId != null &&
                       request.resource.data.classId != null &&
                       request.resource.data.schemaVersion == 1 &&
                       request.resource.data.createdAt != null &&
                       academicYearExists(request.resource.data.academicYearId);
    }
    match /grades/{id} {
      allow read: if isSignedIn() && (
        isStaff() || (userDocExists() && getUserData().profileId == resource.data.studentId)
      );
      allow write: if isStaff();
      
      allow create: if request.resource.data.academicYearId != null &&
                       request.resource.data.studentId != null &&
                       request.resource.data.subjectId != null &&
                       request.resource.data.schemaVersion == 1 &&
                       request.resource.data.createdAt != null &&
                       academicYearExists(request.resource.data.academicYearId);
    }
    match /subjects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /academic_years/{id} {
      allow read: if true;
      allow write: if isAdmin();
      
      allow create: if request.resource.data.schemaVersion == 1 &&
                       request.resource.data.year != null;
    }

    // Classes
    match /classes/{id} {
      allow read: if true;
      allow write: if isAdmin();
      
      allow create: if request.resource.data.academicYearId != null &&
                       academicYearExists(request.resource.data.academicYearId);
    }
    match /schedules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Presensi - CRITICAL for offline-sync validation
    // Collection structure: attendance/{academicYearId}/records/{attendanceId}
    match /attendance/{academicYearId}/records/{attendanceId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      
      // Validate attendance record has required fields
      allow create: if request.resource.data.academicYearId == academicYearId &&
                       request.resource.data.studentId != null &&
                       request.resource.data.classId != null &&
                       request.resource.data.date != null &&
                       request.resource.data.syncStatus in ['pending', 'synced'] &&
                       request.resource.data.schemaVersion == 1 &&
                       request.resource.data.createdAt != null &&
                       academicYearExists(academicYearId);
      
      allow update: if request.resource.data.updatedAt != null &&
                       request.resource.data.syncStatus in ['pending', 'synced'];
    }

    // Layanan Surat & Klaim
    match /letters/{id} {
      allow read: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isStaff();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'Pending');
      
      // Validate schema
      allow write: if request.resource.data.schemaVersion == 1 &&
                      request.resource.data.userId != null;
    }
    match /claim_requests/{id} {
      allow read: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Poin Disiplin
    match /discipline_logs/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      
      allow create: if request.resource.data.studentId != null &&
                       request.resource.data.violationId != null &&
                       request.resource.data.schemaVersion == 1 &&
                       request.resource.data.createdAt != null;
    }
    match /violations_master/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Logs & Settings
    match /login_logs/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    match /audit_logs/{id} {
      allow read, write: if isAdmin();
    }
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /about_content/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default fallback
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}